{
  "manifest_version": 3,
  "name": "Jira Quick Video Recorder",
  "version": "1.2.4",
  "description": "Screen recording with local AI transcription and Jira integration. Built for speed and web compatibility.",
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "Window Recorder"
  },
  "side_panel": {
    "default_path": "src/pages/sidepanel/index.html"
  },
  "permissions": [
    "desktopCapture",
    "downloads",
    "storage",
    "sidePanel",
    "identity",
    "offscreen"
  ],
  "host_permissions": [
    "https://auth.atlassian.com/*",
    "https://api.atlassian.com/*"
  ],
  "background": {
    "service_worker": "src/pages/background/index.ts",
    "type": "module"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/pages/recorder/index.html",
        "models/*",
        "models/**/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}