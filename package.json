{
  "name": "jira-quick-video-recorder",
  "version": "1.2.4",
  "description": "Jira Quick Video Recorder - Screen recording with local AI transcription and Jira integration.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/QuickVideoRecord.git"
  },
  "scripts": {
    "build": "vite build --config vite.config.chrome.ts",
    "build:chrome": "vite build --config vite.config.chrome.ts",
    "build:chromeWithZip": "vite build --config vite.config.chrome.ts && cd dist_chrome && zip -r ../dist_chrome.zip . && cd ..",
    "build:firefox": "vite build --config vite.config.firefox.ts",
    "dev": "nodemon --config nodemon.chrome.json",
    "dev:chrome": "nodemon --config nodemon.chrome.json",
    "dev:firefox": "nodemon --config nodemon.firefox.json",
    "cws:auth": "tsx --env-file=.env scripts/chrome-webstore-auth.ts",
    "cws:upload": "tsx --env-file=.env scripts/chrome-webstore-publish.ts --upload-only",
    "cws:publish": "tsx --env-file=.env scripts/chrome-webstore-publish.ts --publish",
    "cws:status": "tsx --env-file=.env scripts/chrome-webstore-publish.ts --status"
  },
  "type": "module",
  "dependencies": {
    "@atlassian/aui": "^10.0.4",
    "@xenova/transformers": "^2.17.2",
    "fix-webm-duration": "^1.0.6",
    "jira.js": "^5.2.2",
    "lucide-react": "^0.561.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.10.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.3",
    "@tailwindcss/vite": "^4.1.11",
    "@types/chrome": "^0.1.11",
    "@types/dom-chromium-ai": "^0.0.16",
    "@types/node": "^24.9.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/webextension-polyfill": "^0.12.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "fs-extra": "^11.3.2",
    "nodemon": "^3.1.10",
    "tailwindcss": "^4.1.16",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
